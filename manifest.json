{
  "manifest_version": 3,
  "name": "Veris",
  "version": "1.0.0",
  "description": "Local AI text detector and AI image percentage detector.",
  "permissions": [
    "activeTab"
  ],
  "action": {
    "default_title": "Veris",
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
